PORT=5000
# Supports either a single client URL (CLIENT_URL) or a comma-separated list (CLIENT_URLS)
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5174
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=timeflow_db
DB_USER=root
DB_PASSWORD=REPLACE_WITH_REAL_PASSWORD
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
# Keep special characters URL-encoded in DATABASE_URL (e.g. @ as %40)
DATABASE_URL="mysql://root:URL_ENCODED_PASSWORD@127.0.0.1:3306/timeflow_db"
